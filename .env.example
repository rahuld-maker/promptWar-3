# Firebase Client Configuration for Frontend
# Only VITE_ values are exposed to the browser. Do not put backend secrets here.
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend-only configuration
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
GEMINI_API_KEY=your_backend_gemini_key_here
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id"}
# Or use FIREBASE_SERVICE_ACCOUNT_PATH=/secure/path/service-account.json
